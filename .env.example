# Frontend (Vite) environment.
# Copy to .env for local dev. On Vercel, set VITE_API_URL in the project's
# Environment Variables instead.

# Public URL of the backend. For local dev this is the local FastAPI server.
# For production set it to your PC's public tunnel URL (HTTPS), e.g.:
#   VITE_API_URL=https://your-tunnel.trycloudflare.com
VITE_API_URL=http://127.0.0.1:8000
